{
  "name": "@apps/api",
  "private": true,
  "scripts": {
    "start": "node dist/server.js",
    "start:dev": "ts-node src/server.ts",
    "dev": "ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "ts-node prisma/seed.ts",
    "test": "dotenv -e .env.test -- jest --ci --forceExit",
    "test:dev": "jest --ci --forceExit",
    "test:watch": "jest --watch",
    "blueprint": "node blueprint.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "jsonwebtoken": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.1.0",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}