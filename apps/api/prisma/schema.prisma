// ==========================================
// Lease (Swiss rental contract)
// ==========================================
model Lease {
  id     String      @id @default(uuid())
  orgId  String
  status LeaseStatus @default(DRAFT)

  applicationId String?
  unitId        String

  // Template support (building-level lease templates)
  isTemplate         Boolean @default(false)
  templateBuildingId String?
  templateName       String?

  // Parties landlord
  landlordName          String
  landlordAddress       String
  landlordZipCity       String
  landlordPhone         String?
  landlordEmail         String?
  landlordRepresentedBy String?

  // Parties tenant
  tenantName    String
  tenantAddress String?
  tenantZipCity String?
  tenantPhone   String?
  tenantEmail   String?
  coTenantName  String?

  // Object
  objectType           String  @default("APPARTEMENT")
  roomsCount           String?
  floor                String?
  buildingAddressLines Json?
  usageFlags           Json?
  serviceSpaces        Json?
  commonInstallations  Json?

  // Dates / termination
  startDate                  DateTime
  isFixedTerm                Boolean   @default(false)
  endDate                    DateTime?
  firstTerminationDate       DateTime?
  noticeRule                 String    @default("3_MONTHS")
  extendedNoticeText         String?
  terminationDatesRule       String    @default("END_OF_MONTH_EXCEPT_31_12")
  terminationDatesCustomText String?

  // Rent & charges
  netRentChf          Int
  garageRentChf       Int?
  otherServiceRentChf Int?
  chargesItems        Json?
  chargesTotalChf     Int?
  rentTotalChf        Int?

  chargesSettlementDate String?

  paymentDueDayOfMonth Int?
  paymentRecipient     String?
  paymentInstitution   String?
  paymentAccountNumber String?
  paymentIban          String?
  referenceRatePercent String?
  referenceRateDate    String?

  // Deposit
  depositChf     Int?
  depositDueRule String    @default("AT_SIGNATURE")
  depositDueDate DateTime?

  // Stipulations
  otherStipulations  String?
  includesHouseRules Boolean @default(false)
  otherAnnexesText   String?

  // Artifacts
  draftPdfStorageKey String?
  draftPdfSha256     String?

  // Artifacts — signed PDF
  signedPdfStorageKey String?
  signedPdfSha256     String?

  // Deposit payment tracking
  depositPaidAt      DateTime?
  depositConfirmedBy String?
  depositBankRef     String?

  // Activation & termination lifecycle
  activatedAt       DateTime?
  terminatedAt      DateTime?
  terminationReason String?
  terminationNotice String?
  archivedAt        DateTime?

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  org               Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: Restrict)
  signatureRequests SignatureRequest[]
  invoices          Invoice[]
  expenseItems      LeaseExpenseItem[]

  @@index([orgId])
  @@index([unitId])
  @@index([applicationId])
  @@index([status])
}

// ==========================================
// Lease Expense Items (LKDE)
// ==========================================

enum ChargeMode {
  ACOMPTE
  FORFAIT
}

/// Per-lease recurring expense line (heating, water, etc.) with charge mode.
model LeaseExpenseItem {
  id          String     @id @default(uuid())
  leaseId     String
  description String
  amountChf   Int
  mode        ChargeMode @default(ACOMPTE)

  expenseTypeId String?
  accountId     String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lease       Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  expenseType ExpenseType? @relation(fields: [expenseTypeId], references: [id], onDelete: SetNull)
  account     Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([leaseId])
  @@index([expenseTypeId])
  @@index([accountId])
}

// ==========================================
// SignatureRequest (provider-agnostic)
// ==========================================
model SignatureRequest {
  id    String @id @default(uuid())
  orgId String

  entityType String @default("LEASE")
  entityId   String

  provider SignatureProvider      @default(INTERNAL)
  level    SignatureLevel         @default(SES)
  status   SignatureRequestStatus @default(DRAFT)

  providerEnvelopeId String?
  signersJson        Json

  auditTrailStorageKey String?

  sentAt    DateTime?
  signedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  org   Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lease Lease? @relation(fields: [entityId], references: [id])

  @@index([orgId])
  @@index([entityType, entityId])
  @@index([status])
}

// ==========================================
// Rental Application models
// ==========================================

model RentalApplication {
  id        String                  @id @default(uuid())
  orgId     String
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  status    RentalApplicationStatus @default(DRAFT)

  // Submission / signature
  submittedAt        DateTime?
  signedName         String?
  signedAt           DateTime?
  signatureIp        String?
  signatureUserAgent String?

  // Full normalized form payload snapshot (audit/export)
  applicationDataJson Json?

  // Current housing
  currentLandlordName    String?
  currentLandlordAddress String?
  currentLandlordPhone   String?
  reasonForLeaving       String?
  desiredMoveInDate      DateTime?

  // Household info
  householdSize      Int?
  hasPets            Boolean?
  petsDescription    String?
  hasRcInsurance     Boolean?
  rcInsuranceCompany String?
  hasVehicle         Boolean?
  vehicleDescription String?
  needsParking       Boolean?
  remarks            String?

  // Relations
  org              Org                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applicants       RentalApplicant[]
  attachments      RentalAttachment[]
  applicationUnits RentalApplicationUnit[]

  @@index([orgId])
  @@index([status])
}

model RentalApplicant {
  id            String        @id @default(uuid())
  applicationId String
  role          ApplicantRole @default(PRIMARY)

  // Identity
  firstName   String
  lastName    String
  birthdate   DateTime?
  nationality String?
  civilStatus String?
  permitType  String?

  // Contact
  phone String?
  email String?

  // Address
  currentAddress String?
  currentZipCity String?

  // Employment
  employer         String?
  jobTitle         String?
  workLocation     String?
  employedSince    DateTime?
  netMonthlyIncome Int?

  // Debt enforcement
  hasDebtEnforcement Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  application RentalApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  attachments RentalAttachment[]

  @@index([applicationId])
}

model RentalAttachment {
  id            String        @id @default(uuid())
  applicationId String
  applicantId   String
  docType       RentalDocType

  fileName      String
  fileSizeBytes Int
  mimeType      String
  storageKey    String
  sha256        String

  uploadedAt        DateTime  @default(now())
  retentionDeleteAt DateTime?

  // Relations
  application RentalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicant   RentalApplicant   @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([applicantId])
  @@index([retentionDeleteAt])
