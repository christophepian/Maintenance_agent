generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RequestEvent {
  id           String           @id @default(uuid())
  requestId    String
  contractorId String
  type         RequestEventType
  message      String
  timestamp    DateTime         @default(now())
  contractor   Contractor       @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  request      Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([contractorId])
}

model Org {
  id              String           @id @default(uuid())
  name            String
  mode            OrgMode          @default(MANAGED)
  appliances      Appliance[]
  approvalRules   ApprovalRule[]
  assetModels     AssetModel[]
  billingEntities BillingEntity[]
  buildings       Building[]
  buildingConfigs BuildingConfig[]
  contractors     Contractor[]
  invoices        Invoice[]
  jobs            Job[]
  notifications   Notification[]
  config          OrgConfig?
  tenants         Tenant[]
  units           Unit[]
  unitConfigs     UnitConfig[]
  users           User[]
}

model OrgConfig {
  id               String @id @default(uuid())
  orgId            String @unique
  autoApproveLimit Int    @default(200)
  org              Org    @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  orgId        String
  role         Role
  name         String
  createdAt    DateTime @default(now())
  email        String?
  passwordHash String?
  updatedAt    DateTime @updatedAt
  org          Org      @relation(fields: [orgId], references: [id])

  @@unique([orgId, email], name: "user_org_email_unique")
}

model Contractor {
  id                String         @id @default(uuid())
  orgId             String
  name              String
  phone             String
  email             String
  hourlyRate        Int            @default(50)
  serviceCategories String
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  addressLine1      String?
  addressLine2      String?
  postalCode        String?
  city              String?
  country           String?        @default("CH")
  iban              String?
  vatNumber         String?
  defaultVatRate    Float?         @default(7.7)
  billingEntities   BillingEntity?
  org               Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobs              Job[]
  requests          Request[]
  events            RequestEvent[]
}

model Request {
  id                   String         @id @default(uuid())
  description          String
  category             String?
  createdAt            DateTime       @default(now())
  estimatedCost        Int?
  status               RequestStatus  @default(PENDING_REVIEW)
  assignedContractorId String?
  applianceId          String?
  tenantId             String?
  unitId               String?
  contactPhone         String?
  completedAt          DateTime?
  contractorNotes      String?
  startedAt            DateTime?
  updatedAt            DateTime       @default(now()) @updatedAt
  job                  Job?
  appliance            Appliance?     @relation(fields: [applianceId], references: [id])
  assignedContractor   Contractor?    @relation(fields: [assignedContractorId], references: [id])
  tenant               Tenant?        @relation(fields: [tenantId], references: [id])
  unit                 Unit?          @relation(fields: [unitId], references: [id])
  events               RequestEvent[]
}

model Event {
  id          String   @id @default(uuid())
  orgId       String
  type        String
  actorUserId String?
  requestId   String?
  payload     String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([requestId])
}

model Tenant {
  id          String      @id @default(uuid())
  orgId       String
  name        String?
  phone       String
  email       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isActive    Boolean     @default(true)
  occupancies Occupancy[]
  requests    Request[]
  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, phone])
  @@index([orgId, phone])
}

model Building {
  id            String          @id @default(uuid())
  orgId         String
  name          String
  address       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  isActive      Boolean         @default(true)
  approvalRules ApprovalRule[]
  org           Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  config        BuildingConfig?
  notifications Notification[]
  units         Unit[]

  @@index([orgId])
}

model BuildingConfig {
  id                        String   @id @default(uuid())
  orgId                     String
  buildingId                String   @unique
  autoApproveLimit          Int?
  emergencyAutoDispatch     Boolean?
  requireOwnerApprovalAbove Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  building                  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org                       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model UnitConfig {
  id                        String   @id @default(uuid())
  orgId                     String
  unitId                    String   @unique
  autoApproveLimit          Int?
  emergencyAutoDispatch     Boolean?
  requireOwnerApprovalAbove Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  org                       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit                      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Unit {
  id          String      @id @default(uuid())
  buildingId  String
  unitNumber  String
  floor       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isActive    Boolean     @default(true)
  orgId       String
  type        UnitType    @default(RESIDENTIAL)
  appliances  Appliance[]
  occupancies Occupancy[]
  requests    Request[]
  building    Building    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  config      UnitConfig?

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([orgId])
}

model Appliance {
  id           String      @id @default(uuid())
  unitId       String
  assetModelId String?
  name         String
  serial       String?
  installDate  DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isActive     Boolean     @default(true)
  orgId        String
  assetModel   AssetModel? @relation(fields: [assetModelId], references: [id])
  org          Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  requests     Request[]

  @@index([unitId])
  @@index([orgId])
}

model AssetModel {
  id           String      @id @default(uuid())
  orgId        String?
  manufacturer String
  model        String
  category     String
  specs        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isActive     Boolean     @default(true)
  appliances   Appliance[]
  org          Org?        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, manufacturer, model])
  @@index([orgId, category])
  @@index([orgId, isActive])
}

model Occupancy {
  id       String @id @default(uuid())
  tenantId String
  unitId   String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([tenantId, unitId])
  @@index([tenantId])
  @@index([unitId])
}

model Job {
  id           String     @id @default(uuid())
  orgId        String
  requestId    String     @unique
  contractorId String
  status       JobStatus  @default(PENDING)
  actualCost   Int?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  invoices     Invoice[]
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  org          Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  request      Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([contractorId])
  @@index([requestId])
}

model BillingEntity {
  id                  String            @id @default(uuid())
  orgId               String
  type                BillingEntityType
  name                String
  addressLine1        String
  addressLine2        String?
  postalCode          String
  city                String
  country             String            @default("CH")
  iban                String
  vatNumber           String?
  defaultVatRate      Float             @default(7.7)
  nextInvoiceSequence Int               @default(1)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  contractorId        String?           @unique
  contractor          Contractor?       @relation(fields: [contractorId], references: [id])
  org                 Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices            Invoice[]

  @@unique([orgId, type])
  @@index([orgId])
}

model Invoice {
  id                    String            @id @default(uuid())
  orgId                 String
  jobId                 String
  amount                Int
  description           String
  status                InvoiceStatus     @default(DRAFT)
  submittedAt           DateTime?
  approvedAt            DateTime?
  paidAt                DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  issuerBillingEntityId String?
  recipientName         String            @default("Unknown")
  recipientAddressLine1 String            @default("Unknown")
  recipientAddressLine2 String?
  recipientPostalCode   String            @default("0000")
  recipientCity         String            @default("Unknown")
  recipientCountry      String            @default("CH")
  issueDate             DateTime?
  dueDate               DateTime?
  invoiceNumber         String?
  invoiceNumberFormat   String            @default("YYYY-NNN")
  subtotalAmount        Int               @default(0)
  vatAmount             Int               @default(0)
  totalAmount           Int               @default(0)
  currency              String            @default("CHF")
  vatRate               Float             @default(7.7)
  paymentReference      String?
  iban                  String?
  lockedAt              DateTime?
  issuer                BillingEntity?    @relation(fields: [issuerBillingEntityId], references: [id])
  job                   Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  org                   Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lineItems             InvoiceLineItem[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([jobId])
  @@index([status])
  @@index([issuerBillingEntityId])
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float    @default(1.0)
  unitPrice   Int
  vatRate     Float    @default(7.7)
  lineTotal   Int
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ApprovalRule {
  id         String     @id @default(uuid())
  orgId      String
  buildingId String?
  name       String
  priority   Int        @default(0)
  isActive   Boolean    @default(true)
  conditions String
  action     RuleAction
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  building   Building?  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org        Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, buildingId, priority])
  @@index([orgId, isActive])
}

model Notification {
  id         String                @id @default(uuid())
  orgId      String
  userId     String
  buildingId String?
  entityType String
  entityId   String
  eventType  NotificationEventType
  message    String?
  readAt     DateTime?
  createdAt  DateTime              @default(now())
  building   Building?             @relation(fields: [buildingId], references: [id])
  org        Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, entityType, entityId, eventType])
  @@index([orgId, userId])
  @@index([orgId, buildingId])
  @@index([orgId, userId, readAt])
}

enum RequestEventType {
  ARRIVED
  PARTS_ORDERED
  COMPLETED
  NOTE
  OTHER
  OWNER_APPROVED
  OWNER_REJECTED
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  INVOICED
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  PAID
  DISPUTED
  ISSUED
}

enum Role {
  TENANT
  CONTRACTOR
  MANAGER
  OWNER
}

enum RequestStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  IN_PROGRESS
  COMPLETED
  ASSIGNED
  PENDING_OWNER_APPROVAL
}

enum UnitType {
  RESIDENTIAL
  COMMON_AREA
}

enum OrgMode {
  MANAGED
  OWNER_DIRECT
}

enum BillingEntityType {
  CONTRACTOR
  ORG
  OWNER
}

enum RuleAction {
  AUTO_APPROVE
  REQUIRE_MANAGER_REVIEW
  REQUIRE_OWNER_APPROVAL
}

enum NotificationEventType {
  REQUEST_APPROVED
  REQUEST_PENDING_REVIEW
  REQUEST_PENDING_OWNER_APPROVAL
  CONTRACTOR_ASSIGNED
  CONTRACTOR_REJECTED
  JOB_CREATED
  JOB_STARTED
  JOB_COMPLETED
  INVOICE_CREATED
  INVOICE_APPROVED
  INVOICE_PAID
  INVOICE_DISPUTED
  OWNER_REJECTED
}
