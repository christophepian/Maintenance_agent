generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Legal Engine Enums
// ==========================================

enum LegalAuthority {
  STATUTE
  INDUSTRY_STANDARD
}

enum LegalRuleType {
  MAINTENANCE_OBLIGATION
  DEPRECIATION
  RENT_INDEXATION
  RENT_REDUCTION
  TERMINATION_DEADLINE
}

enum LegalRuleScope {
  FEDERAL
  CANTONAL
  MUNICIPAL
}

enum LegalObligation {
  OBLIGATED
  DISCRETIONARY
  TENANT_RESPONSIBLE
  UNKNOWN
}

enum AssetType {
  APPLIANCE
  FIXTURE
  FINISH
  STRUCTURAL
  SYSTEM
  OTHER
}

enum SlotStatus {
  PROPOSED
  ACCEPTED
  DECLINED
}

enum RfpStatus {
  DRAFT
  OPEN
  CLOSED
  AWARDED
  CANCELLED
  PENDING_OWNER_APPROVAL
}

enum RfpQuoteStatus {
  SUBMITTED
  AWARDED
  REJECTED
}

enum RfpInviteStatus {
  INVITED
  DECLINED
  RESPONDED
}

enum LegalSourceStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum LegalSourceScope {
  FEDERAL
  AG
  AL
  AR
  AI
  BE
  BL
  BS
  FR
  GE
  GL
  GR
  JU
  LU
  NE
  NW
  OW
  SG
  SH
  SO
  SZ
  TG
  TI
  UR
  VD
  VS
  ZG
  ZH
}

model RequestEvent {
  id           String           @id @default(uuid())
  requestId    String
  contractorId String
  type         RequestEventType
  message      String
  timestamp    DateTime         @default(now())
  contractor   Contractor       @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  request      Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([contractorId])
}

model Org {
  id                    String                      @id @default(uuid())
  name                  String
  mode                  OrgMode                     @default(MANAGED)
  appliances            Appliance[]
  approvalRules         ApprovalRule[]
  assetModels           AssetModel[]
  billingEntities       BillingEntity[]
  buildings             Building[]
  buildingConfigs       BuildingConfig[]
  contractors           Contractor[]
  invoices              Invoice[]
  jobs                  Job[]
  notifications         Notification[]
  config                OrgConfig?
  tenants               Tenant[]
  units                 Unit[]
  unitConfigs           UnitConfig[]
  users                 User[]
  leases                Lease[]
  signatureRequests     SignatureRequest[]
  rentalApplications    RentalApplication[]
  emailOutbox           EmailOutbox[]
  rentEstimationConfigs RentEstimationConfig[]
  financialSnapshots    BuildingFinancialSnapshot[]
  // Legal engine relations
  legalEvaluationLogs   LegalEvaluationLog[]
  legalCategoryMappings LegalCategoryMapping[]
  assets                Asset[]
  rfps                  Rfp[]
  appointmentSlots      AppointmentSlot[]
  jobRatings             JobRating[]
  // Chart-of-Accounts (FIN-COA)
  expenseTypes          ExpenseType[]
  accounts              Account[]
  expenseMappings       ExpenseMapping[]
  // Ledger
  ledgerEntries         LedgerEntry[]
  // Capture Sessions (INV-HUB)
  captureSessions       CaptureSession[]
}

model OrgConfig {
  id               String  @id @default(uuid())
  orgId            String  @unique
  autoApproveLimit Int     @default(200)
  autoLegalRouting Boolean @default(false)

  // Landlord party info (for lease)
  landlordName          String?
  landlordAddress       String?
  landlordZipCity       String?
  landlordPhone         String?
  landlordEmail         String?
  landlordRepresentedBy String?

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(uuid())
  orgId        String
  role         Role
  name         String
  createdAt    DateTime @default(now())
  email          String?
  passwordHash   String?
  updatedAt      DateTime        @updatedAt
  org            Org             @relation(fields: [orgId], references: [id])
  ownedBuildings BuildingOwner[]
  billingEntity  BillingEntity?

  @@unique([orgId, email], name: "user_org_email_unique")
  @@index([orgId])
}

model Contractor {
  id                String         @id @default(uuid())
  orgId             String
  name              String
  phone             String
  email             String
  hourlyRate        Int            @default(50)
  serviceCategories String
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  addressLine1      String?
  addressLine2      String?
  postalCode        String?
  city              String?
  country           String?        @default("CH")
  iban              String?
  vatNumber         String?
  defaultVatRate    Float?         @default(7.7)
  billingEntities   BillingEntity?
  org               Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  jobs              Job[]
  requests          Request[]
  events            RequestEvent[]
  rfpInvites        RfpInvite[]
  rfpQuotes         RfpQuote[]
  awardedRfps       Rfp[]          @relation("AwardedContractor")
}

model Request {
  id                   String         @id @default(uuid())
  orgId                String         @default("")
  requestNumber        Int            @default(autoincrement()) @unique
  description          String
  category             String?
  createdAt            DateTime       @default(now())
  estimatedCost        Int?
  status               RequestStatus  @default(PENDING_REVIEW)
  assignedContractorId String?
  applianceId          String?
  tenantId             String?
  unitId               String?
  contactPhone         String?
  completedAt          DateTime?
  contractorNotes      String?
  startedAt            DateTime?
  updatedAt            DateTime       @default(now()) @updatedAt
  approvalSource       ApprovalSource?
  rejectionReason      String?
  payingParty          PayingParty     @default(LANDLORD)
  urgency              RequestUrgency  @default(MEDIUM)
  job                  Job?
  appliance            Appliance?     @relation(fields: [applianceId], references: [id])
  assignedContractor   Contractor?    @relation(fields: [assignedContractorId], references: [id])
  tenant               Tenant?        @relation(fields: [tenantId], references: [id])
  unit                 Unit?          @relation(fields: [unitId], references: [id])
  events               RequestEvent[]
  attachments          MaintenanceAttachment[]
  rfps                 Rfp[]

  @@index([orgId])
}

model MaintenanceAttachment {
  id          String   @id @default(uuid())
  requestId   String
  fileName    String
  mimeType    String
  storageKey  String
  sizeBytes   Int
  uploadedBy  String?
  createdAt   DateTime @default(now())
  request     Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Event {
  id          String   @id @default(uuid())
  orgId       String
  type        String
  actorUserId String?
  requestId   String?
  payload     String   @default("{}")
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([requestId])
}

model Tenant {
  id          String      @id @default(uuid())
  orgId       String
  name        String?
  phone       String
  email       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isActive    Boolean     @default(true)
  occupancies Occupancy[]
  requests    Request[]
  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, phone])
  @@index([orgId, phone])
}

model Building {
  id      String @id @default(uuid())
  orgId   String
  name    String
  address String

  // Rent estimation fields
  yearBuilt    Int?
  hasElevator  Boolean @default(false)
  hasConcierge Boolean @default(false)

  // Management
  managedSince DateTime?

  // Legal engine: canton derivation
  canton          String?
  cantonDerivedAt DateTime?

  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  isActive           Boolean                     @default(true)
  approvalRules      ApprovalRule[]
  org                Org                         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  config             BuildingConfig?
  notifications      Notification[]
  units              Unit[]
  financialSnapshots BuildingFinancialSnapshot[]
  rfps               Rfp[]
  owners             BuildingOwner[]
  expenseMappings    ExpenseMapping[]
  ledgerEntries      LedgerEntry[]

  @@index([orgId])
}

model BuildingOwner {
  id         String   @id @default(uuid())
  buildingId String
  userId     String
  createdAt  DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildingId, userId])
  @@index([buildingId])
  @@index([userId])
}

model BuildingConfig {
  id                        String   @id @default(uuid())
  orgId                     String
  buildingId                String   @unique
  autoApproveLimit          Int?
  emergencyAutoDispatch     Boolean?
  requireOwnerApprovalAbove Int?
  // RFP policy
  rfpDefaultInviteCount     Int?     @default(3)

  // Rental application policy
  rentalIncomeMultiplier                Float? @default(3)
  rentalSignatureDeadlineDays           Int?   @default(7)
  rentalManualReviewConfidenceThreshold Int?   @default(60)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  building  Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model UnitConfig {
  id                        String   @id @default(uuid())
  orgId                     String
  unitId                    String   @unique
  autoApproveLimit          Int?
  emergencyAutoDispatch     Boolean?
  requireOwnerApprovalAbove Int?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  org                       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit                      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Unit {
  id         String   @id @default(uuid())
  buildingId String
  unitNumber String
  floor      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isActive   Boolean  @default(true)
  orgId      String
  type       UnitType @default(RESIDENTIAL)

  // Vacancy fields (rental applications)
  isVacant          Boolean @default(false)
  monthlyRentChf    Int?
  monthlyChargesChf Int?

  // Rent estimation fields
  livingAreaSqm      Float?
  rooms              Float? // allow 3.5 etc
  hasBalcony         Boolean            @default(false)
  hasTerrace         Boolean            @default(false)
  hasParking         Boolean            @default(false)
  locationSegment    LocationSegment?
  lastRenovationYear Int?
  insulationQuality  InsulationQuality?
  energyLabel        EnergyLabel?
  heatingType        HeatingType?

  appliances             Appliance[]
  occupancies            Occupancy[]
  requests               Request[]
  building               Building                @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org                    Org                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  config                 UnitConfig?
  leases                 Lease[]
  rentalApplicationUnits RentalApplicationUnit[]
  ownerSelections        RentalOwnerSelection[]
  assets                 Asset[]
  rfps                   Rfp[]
  ledgerEntries          LedgerEntry[]

  @@unique([buildingId, unitNumber])
  @@index([buildingId])
  @@index([orgId])
  @@index([isVacant])
}

model RentEstimationConfig {
  id     String  @id @default(uuid())
  orgId  String
  canton String? // e.g. "ZH", "GE"; null = org default

  // Base rent
  baseRentPerSqmChfMonthly Float @default(20)

  // Location coefficients
  locationCoefPrime     Float @default(1.30)
  locationCoefStandard  Float @default(1.00)
  locationCoefPeriphery Float @default(0.85)

  // Age coefficients
  ageCoefNew     Float @default(1.10)
  ageCoefMid     Float @default(1.00)
  ageCoefOld     Float @default(0.95)
  ageCoefVeryOld Float @default(0.90)

  // Energy coefficient map (JSON)
  energyCoefJson Json @default("{\"A\":1.05,\"B\":1.03,\"C\":1.01,\"D\":1.00,\"E\":0.98,\"F\":0.95,\"G\":0.90}")

  // Charges
  chargesBaseOptimistic     Float @default(0.10)
  chargesBasePessimistic    Float @default(0.20)
  heatingChargeAdjJson      Json  @default("{\"HEAT_PUMP\":-0.02,\"DISTRICT\":-0.01,\"GAS\":0,\"OIL\":0.02,\"ELECTRIC\":0.03,\"UNKNOWN\":0}")
  serviceChargeAdjElevator  Float @default(0.01)
  serviceChargeAdjConcierge Float @default(0.02)
  chargesMinClamp           Float @default(0.08)
  chargesMaxClamp           Float @default(0.25)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, canton])
  @@index([orgId])
}

model Appliance {
  id           String      @id @default(uuid())
  unitId       String
  assetModelId String?
  name         String
  serial       String?
  installDate  DateTime?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isActive     Boolean     @default(true)
  orgId        String
  assetModel   AssetModel? @relation(fields: [assetModelId], references: [id])
  org          Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  requests     Request[]

  @@index([unitId])
  @@index([orgId])
}

model AssetModel {
  id           String      @id @default(uuid())
  orgId        String?
  manufacturer String
  model        String
  category     String
  specs        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  isActive     Boolean     @default(true)
  appliances   Appliance[]
  org          Org?        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, manufacturer, model])
  @@index([orgId, category])
  @@index([orgId, isActive])
}

model Occupancy {
  id       String @id @default(uuid())
  tenantId String
  unitId   String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([tenantId, unitId])
  @@index([tenantId])
  @@index([unitId])
}

model Job {
  id                  String     @id @default(uuid())
  orgId               String
  requestId           String     @unique
  contractorId        String
  status              JobStatus  @default(PENDING)
  actualCost          Int?
  startedAt           DateTime?
  completedAt         DateTime?
  schedulingExpiresAt DateTime?
  confirmedAt         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  invoices            Invoice[]
  interventions       AssetIntervention[]
  appointmentSlots    AppointmentSlot[]
  ratings             JobRating[]
  contractor          Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  org                 Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  request             Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([contractorId])
  @@index([requestId])
}

model BillingEntity {
  id                  String            @id @default(uuid())
  orgId               String
  type                BillingEntityType
  name                String
  addressLine1        String
  addressLine2        String?
  postalCode          String
  city                String
  country             String            @default("CH")
  iban                String
  vatNumber           String?
  defaultVatRate      Float             @default(7.7)
  nextInvoiceSequence Int               @default(1)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  contractorId        String?           @unique
  userId              String?           @unique
  contractor          Contractor?       @relation(fields: [contractorId], references: [id])
  user                User?             @relation(fields: [userId], references: [id])
  org                 Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices            Invoice[]

  @@index([orgId])
}

model Invoice {
  id                    String                @id @default(uuid())
  orgId                 String
  jobId                 String?
  leaseId               String?
  amount                Int
  description           String
  status                InvoiceStatus         @default(DRAFT)
  submittedAt           DateTime?
  approvedAt            DateTime?
  paidAt                DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  issuerBillingEntityId String?
  recipientName         String                @default("Unknown")
  recipientAddressLine1 String                @default("Unknown")
  recipientAddressLine2 String?
  recipientPostalCode   String                @default("0000")
  recipientCity         String                @default("Unknown")
  recipientCountry      String                @default("CH")
  issueDate             DateTime?
  dueDate               DateTime?
  invoiceNumber         String?
  invoiceNumberFormat   String                @default("YYYY-NNN")
  subtotalAmount        Int                   @default(0)
  vatAmount             Int                   @default(0)
  totalAmount           Int                   @default(0)
  currency              String                @default("CHF")
  vatRate               Float                 @default(7.7)
  paymentReference      String?
  iban                  String?
  lockedAt              DateTime?
  expenseTypeId         String?
  accountId             String?
  // ── Ingestion / Hub fields (INV-HUB epic) ────────────────
  direction             InvoiceDirection      @default(OUTGOING)
  sourceChannel         InvoiceSourceChannel  @default(MANUAL)
  ingestionStatus       IngestionStatus?
  rawOcrText            String?
  ocrConfidence         Int?
  sourceFileUrl         String?
  matchedJobId          String?
  matchedLeaseId        String?
  matchedBuildingId     String?
  // ── Relations ────────────────────────────────────────────
  issuer                BillingEntity?        @relation(fields: [issuerBillingEntityId], references: [id])
  job                   Job?                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  org                   Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lease                 Lease?                @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  classifiedExpenseType ExpenseType?          @relation(fields: [expenseTypeId], references: [id], onDelete: SetNull)
  classifiedAccount     Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  expenseCategory       ExpenseCategory?
  lineItems             InvoiceLineItem[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([jobId])
  @@index([leaseId])
  @@index([status])
  @@index([issuerBillingEntityId])
  @@index([direction])
  @@index([ingestionStatus])
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float    @default(1.0)
  unitPrice   Int
  vatRate     Float    @default(7.7)
  lineTotal   Int
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ApprovalRule {
  id         String     @id @default(uuid())
  orgId      String
  buildingId String?
  name       String
  priority   Int        @default(0)
  isActive   Boolean    @default(true)
  conditions String
  action     RuleAction
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  building   Building?  @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  org        Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, buildingId, priority])
  @@index([orgId, isActive])
}

model Notification {
  id         String                @id @default(uuid())
  orgId      String
  userId     String
  buildingId String?
  entityType String
  entityId   String
  eventType  NotificationEventType
  message    String?
  readAt     DateTime?
  createdAt  DateTime              @default(now())
  building   Building?             @relation(fields: [buildingId], references: [id])
  org        Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, entityType, entityId, eventType])
  @@index([orgId, userId])
  @@index([orgId, buildingId])
  @@index([orgId, userId, readAt])
}

// ═══════════════════════════════════════════════════════════
// Capture Sessions (INV-HUB: QR-based phone handoff for paper invoices)
// ═══════════════════════════════════════════════════════════

model CaptureSession {
  id               String               @id @default(cuid())
  orgId            String
  createdBy        String               // userId of the manager who created the session
  token            String               @unique // signed JWT for token-gated access
  status           CaptureSessionStatus @default(CREATED)
  expiresAt        DateTime
  sourceChannel    InvoiceSourceChannel @default(MOBILE_CAPTURE)
  targetType       String               @default("INVOICE") // extensible for future doc types
  uploadedFileUrls String[]             @default([])
  createdInvoiceId String?              // FK to Invoice created from this session
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  org              Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([token])
  @@index([expiresAt])
}

enum CaptureSessionStatus {
  CREATED
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum RequestEventType {
  ARRIVED
  PARTS_ORDERED
  COMPLETED
  NOTE
  OTHER
  OWNER_APPROVED
  OWNER_REJECTED
  TENANT_SELECTED // Orphan: added during tenant-selection epic but never emitted in request event logs — kept for DB compatibility
}

enum RaterRole {
  CONTRACTOR
  TENANT
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  INVOICED
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  PAID
  DISPUTED
  ISSUED
}

enum InvoiceDirection {
  OUTGOING
  INCOMING
}

enum InvoiceSourceChannel {
  MANUAL
  BROWSER_UPLOAD
  EMAIL_PDF
  MOBILE_CAPTURE
}

enum IngestionStatus {
  PENDING_REVIEW
  CONFIRMED
  AUTO_CONFIRMED
  REJECTED
}

enum ExpenseCategory {
  MAINTENANCE
  UTILITIES
  CLEANING
  INSURANCE
  TAX
  ADMIN
  CAPEX
  OTHER
}

enum Role {
  TENANT
  CONTRACTOR
  MANAGER
  OWNER
  VENDOR
  INSURANCE
}

enum RequestStatus {
  PENDING_REVIEW
  AUTO_APPROVED
  APPROVED
  RFP_PENDING
  IN_PROGRESS
  COMPLETED
  ASSIGNED
  PENDING_OWNER_APPROVAL
  OWNER_REJECTED
}

enum ApprovalSource {
  SYSTEM_AUTO
  OWNER_APPROVED
  OWNER_REJECTED
  LEGAL_OBLIGATION
}

enum PayingParty {
  LANDLORD
  TENANT
}

enum RequestUrgency {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum UnitType {
  RESIDENTIAL
  COMMON_AREA
}

enum OrgMode {
  MANAGED
  OWNER_DIRECT
}

enum BillingEntityType {
  CONTRACTOR
  ORG
  OWNER
}

enum RuleAction {
  AUTO_APPROVE
  REQUIRE_MANAGER_REVIEW
  REQUIRE_OWNER_APPROVAL
}

enum NotificationEventType {
  REQUEST_APPROVED
  REQUEST_PENDING_REVIEW
  REQUEST_PENDING_OWNER_APPROVAL
  CONTRACTOR_ASSIGNED
  CONTRACTOR_REJECTED
  JOB_CREATED
  JOB_STARTED
  JOB_COMPLETED
  INVOICE_CREATED
  INVOICE_APPROVED
  INVOICE_PAID
  INVOICE_DISPUTED
  OWNER_REJECTED
  TENANT_SELF_PAY_ACCEPTED
  TENANT_SELECTED
  LEASE_READY_TO_SIGN
  LEASE_SIGNED
  APPLICATION_SUBMITTED
  QUOTE_SUBMITTED
  QUOTE_AWARDED
  QUOTE_REJECTED
  SLOT_PROPOSED
  SLOT_ACCEPTED
  SLOT_DECLINED
  SCHEDULING_ESCALATED
  JOB_CONFIRMED
  RATING_SUBMITTED
}

// ==========================================
// Lease & Signature enums
// ==========================================

enum LeaseStatus {
  DRAFT
  READY_TO_SIGN
  SIGNED
  ACTIVE
  TERMINATED
  CANCELLED
}

enum SignatureProvider {
  INTERNAL
  DOCUSIGN
  SKRIBBLE
}

enum SignatureLevel {
  SES
  AES
  QES
}

enum SignatureRequestStatus {
  DRAFT
  SENT
  SIGNED
  DECLINED
  EXPIRED
  ERROR
}

// ==========================================
// Rental Application enums
// ==========================================

enum RentalApplicationStatus {
  DRAFT
  SUBMITTED
}

enum ApplicantRole {
  PRIMARY
  CO_APPLICANT
}

