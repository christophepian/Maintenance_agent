model RentalApplicationUnit {
  id            String                      @id @default(uuid())
  applicationId String
  unitId        String
  createdAt     DateTime                    @default(now())
  status        RentalApplicationUnitStatus @default(SUBMITTED)

  // Evaluation results
  evaluationJson      Json?
  scoreTotal          Int?
  confidenceScore     Int?
  disqualified        Boolean @default(false)
  disqualifiedReasons Json?
  rank                Int?

  // Manager override
  managerScoreDelta     Int?
  managerOverrideJson   Json?
  managerOverrideReason String?

  // Relations
  application       RentalApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  unit              Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  primarySelections RentalOwnerSelection[] @relation("PrimarySelection")
  backup1Selections RentalOwnerSelection[] @relation("Backup1Selection")
  backup2Selections RentalOwnerSelection[] @relation("Backup2Selection")

  @@unique([applicationId, unitId])
  @@index([applicationId])
  @@index([unitId])
  @@index([unitId, rank])
