// ==========================================
// Chart of Accounts (FIN-COA)
// ==========================================

/// Canonical expense category for a building cost (e.g. "Electricity – Common Areas").
model ExpenseType {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  code        String?  /// Optional short code like "ELEC-CA"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mappings ExpenseMapping[]
  invoices Invoice[]
  leaseExpenseItems LeaseExpenseItem[]

  @@unique([orgId, name])
  @@index([orgId])
}

/// Accounting bucket into which expenses are classified (e.g. "Nebenkosten – recoverable").
model Account {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  code        String?  /// e.g. "4000"
  accountType String   @default("EXPENSE") /// EXPENSE | REVENUE | ASSET | LIABILITY — standard double-entry account classes
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org      Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  mappings           ExpenseMapping[]
  invoices           Invoice[]
  ledgerEntries      LedgerEntry[]
  leaseExpenseItems  LeaseExpenseItem[]

  @@unique([orgId, name])
  @@index([orgId])
}

/// Links an ExpenseType to an Account, optionally scoped to a building.
model ExpenseMapping {
  id            String   @id @default(uuid())
  orgId         String
  expenseTypeId String
  accountId     String
  buildingId    String?  /// null = org-wide default; non-null = building override
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  expenseType ExpenseType @relation(fields: [expenseTypeId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  building    Building?   @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@unique([orgId, expenseTypeId, buildingId])
  @@index([orgId])
  @@index([expenseTypeId])
  @@index([accountId])
}

// ==========================================
// Ledger
// ==========================================

/// One leg of a double-entry journal posting.
/// Each economic event (invoice payment, rent receipt, etc.) produces two entries:
/// a debit leg and a credit leg grouped by the same journalId.
/// debitCents and creditCents are mutually exclusive — exactly one is non-zero per row.
/// Amounts are stored in CHF cents (integer) to avoid floating-point rounding.
model LedgerEntry {
  id          String   @id @default(uuid())
  orgId       String
  date        DateTime /// Economic date of the transaction
  accountId   String
  debitCents  Int      @default(0) /// Amount debited in CHF cents (increases ASSET/EXPENSE accounts)
  creditCents Int      @default(0) /// Amount credited in CHF cents (increases LIABILITY/REVENUE accounts)
  description String   /// Human-readable posting description
  reference   String?  /// Invoice number, payment reference, or other external identifier
  sourceType  String?  /// "INVOICE_ISSUED" | "INVOICE_PAID" | "RENT_RECEIPT" | "MANUAL"
  sourceId    String?  /// UUID of the originating domain record
  journalId   String   /// UUID grouping all legs of one posting (generated per transaction)
  buildingId  String?  /// Optional building scope for per-building reporting
  unitId      String?  /// Optional unit scope for per-unit attribution
  createdBy   String?  /// userId for manual entries; null for auto-posted entries
  createdAt   DateTime @default(now())

  org      Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  account  Account   @relation(fields: [accountId], references: [id])
  building Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit     Unit?     @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([orgId, date])
  @@index([accountId])
  @@index([journalId])
  @@index([sourceType, sourceId])
  @@index([buildingId])
  @@index([unitId])
}
