model RentalOwnerSelection {
  id         String    @id @default(uuid())
  unitId     String
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?
  deadlineAt DateTime

  primaryApplicationUnitId String
  backup1ApplicationUnitId String?
  backup2ApplicationUnitId String?

  status RentalOwnerSelectionStatus @default(AWAITING_SIGNATURE)

  // Relations
  unit             Unit                   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  primarySelection RentalApplicationUnit  @relation("PrimarySelection", fields: [primaryApplicationUnitId], references: [id])
  backup1Selection RentalApplicationUnit? @relation("Backup1Selection", fields: [backup1ApplicationUnitId], references: [id])
  backup2Selection RentalApplicationUnit? @relation("Backup2Selection", fields: [backup2ApplicationUnitId], references: [id])

  @@index([unitId])
  @@index([status])
  @@index([deadlineAt])
}

model EmailOutbox {
  id         String            @id @default(uuid())
  orgId      String
  createdAt  DateTime          @default(now())
  toEmail    String
  template   EmailTemplate
  subject    String
  bodyText   String
  status     EmailOutboxStatus @default(PENDING)
  retryCount Int               @default(0)
  metaJson   Json?

  // Relations
  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
}

