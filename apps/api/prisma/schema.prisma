// ==========================================
// Legal Engine Models
// ==========================================

model LegalSource {
  id              String            @id @default(uuid())
  name            String
  jurisdiction    String            @default("CH")
  scope           LegalSourceScope  @default(FEDERAL)
  url             String?
  updateFrequency String?
  fetcherType     String?
  parserType      String?
  status          LegalSourceStatus @default(ACTIVE)
  lastCheckedAt   DateTime?
  lastSuccessAt   DateTime?
  lastError       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  variableVersions      LegalVariableVersion[]
  depreciationStandards DepreciationStandard[]

  @@index([jurisdiction])
  @@index([status])
}

model LegalVariable {
  id           String   @id @default(uuid())
  key          String
  jurisdiction String   @default("CH")
  canton       String?
  unit         String?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  versions LegalVariableVersion[]

  @@unique([key, jurisdiction, canton])
  @@index([jurisdiction])
}

model LegalVariableVersion {
  id            String    @id @default(uuid())
  variableId    String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  valueJson     Json
  sourceId      String?
  fetchedAt     DateTime?
  createdAt     DateTime  @default(now())

  variable LegalVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)
  source   LegalSource?  @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([variableId, effectiveFrom])
  @@index([sourceId])
}

model LegalRule {
  id           String         @id @default(uuid())
  key          String
  ruleType     LegalRuleType
  authority    LegalAuthority
  jurisdiction String         @default("CH")
  canton       String?
  topic        String?
  scope        LegalRuleScope @default(FEDERAL)
  priority     Int            @default(0)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  versions LegalRuleVersion[]

  @@unique([key])
  @@index([ruleType, jurisdiction])
  @@index([isActive])
}

model LegalRuleVersion {
  id            String    @id @default(uuid())
  ruleId        String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  dslJson       Json
  citationsJson Json?
  summary       String?
  createdAt     DateTime  @default(now())

  rule LegalRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, effectiveFrom])
}

model LegalEvaluationLog {
  id                        String   @id @default(uuid())
  orgId                     String
  buildingId                String?
  unitId                    String?
  requestId                 String?
  contextJson               Json
  contextHash               String
  resultJson                Json
  matchedRuleVersionIdsJson Json?
  createdAt                 DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([requestId])
  @@index([contextHash])
}

model LegalCategoryMapping {
  id              String  @id @default(uuid())
  orgId           String?
  requestCategory String
  legalTopic      String
  confidence      Float   @default(1.0)
  isActive        Boolean @default(true)

  org Org? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, requestCategory])
  @@index([requestCategory])
  @@index([isActive])
}

