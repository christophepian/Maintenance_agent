# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development                      # development | production | test
REQUEST_TIMEOUT_MS=30000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/maint_agent

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production       # Required in production; JWT signing key
AUTH_OPTIONAL=false                       # Set to "true" in dev to bypass JWT checks
DEV_IDENTITY_ENABLED=false               # Set to "true" to allow x-dev-user-id header in dev
DEV_ORG_ID=                              # Default org for dev identity bypass (optional)
ALLOW_OWNER_REGISTRATION=false           # Allow owner self-registration in dev only

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000        # In production, set to your frontend domain
FRONTEND_URL=http://localhost:3000       # Used for QR bill / tenant links; must match frontend origin

# ── Background jobs ───────────────────────────────────────────────────────────
BG_JOBS_ENABLED=true                     # Set to "false" to disable scheduled background jobs
BG_JOB_INTERVAL_MS=3600000              # Background job interval in ms (default: 1 hour)
OVERDUE_GRACE_HOURS=24                   # Hours after due-date before a charge is flagged overdue

# ── File storage ──────────────────────────────────────────────────────────────
ATTACHMENTS_STORAGE=local               # "local" | "s3" (s3 not yet implemented)
ATTACHMENTS_LOCAL_ROOT=./uploads        # Root path for local attachment storage

# ── Document scanning ────────────────────────────────────────────────────────
DOCUMENT_SCAN_PROVIDER=azure            # "local" | "azure"
DOCUMENT_SCAN_FALLBACK_PROVIDER=local   # optional: fallback provider if primary fails

# Azure Document Intelligence (required when DOCUMENT_SCAN_PROVIDER=azure)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://maintenance-agent-docintel.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-azure-document-intelligence-key
# AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-layout   # optional, default: prebuilt-layout

# ── Email delivery ────────────────────────────────────────────────────────────
# Provider priority: Resend > SMTP > dev console (logs to stdout).
# Set EMAIL_FROM_ADDRESS to control the From: address for all providers.
# EMAIL_FROM_ADDRESS=noreply@example.com

# Option A — Resend (recommended for production)
# RESEND_API_KEY=re_...

# Option B — SMTP (nodemailer)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@example.com   # legacy alias for EMAIL_FROM_ADDRESS
